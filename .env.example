# ── Database ──────────────────────────────────────────────────────────────────
# Railway: copy from the PostgreSQL service's "Connect" tab
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# ── Redis ─────────────────────────────────────────────────────────────────────
# Railway: copy from the Redis service's "Connect" tab
REDIS_URL=redis://default:PASSWORD@HOST:PORT

# ── Auth (better-auth) ────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=

# ── OAuth providers (optional) ────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── App URL ───────────────────────────────────────────────────────────────────
# Production: your Railway or Vercel URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Sentry (optional — leave blank to disable) ────────────────────────────────
# Create a project at sentry.io → Settings → Projects → DSN
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Required for uploading source maps during build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
